#include<iostream>
#include<string>
using namespace std;
class nnew
{
    string s;
    int count=1;
    public:
    void input()
    {
        cout<<"enter the string:";
        getline(cin,s);
    }
    void calculate()
    {
        for(int i=0;i<s.length();i++)
        {
            if(s[i]==' ')
            {
                count++;
            }
        }
    }
    void display()
    {
        cout<<"number of words in the string are:";
        cout<<count;
    }
};
