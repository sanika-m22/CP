#include <iostream>
#include <string>
using namespace std;

class New {
    string s;
    int count = 1;

public:
    void input() {
        cout << "\n Enter a string: ";
        getline(cin, s);
    }

    void calculate() {
        for (int i = 0; i < s.length(); i++) {
            if (s[i] == ' ') {
                count++;
            }
        }
    }

    void display() {
        cout << "\n Number of words: " << count << endl;
    }
};

int main() {
    New n;
    n.input();
    n.calculate();
    n.display();
    return 0;
}
